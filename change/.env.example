# Copy this file to .env on the machine that will run downloads or training.
# Do not commit .env.

# GitHub private repo access, if needed by scripts.
GITHUB_TOKEN=

# Hugging Face datasets/models, if used later.
HF_TOKEN=

# Kaggle datasets, if used later.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Zenodo restricted/request-access downloads, if granted.
ZENODO_TOKEN=

# Experiment tracking, optional.
WANDB_API_KEY=
WANDB_MODE=offline

# LLM assistance, optional. Do not let agents print this value.
OPENAI_API_KEY=

