# Datasets and model artifacts — never commit
data/
*/data/
outputs/
*/outputs/
*.pt
*.pth
*.ckpt
*.stl
*.ply
*.obj

# ...but toothprint/bench/data is vendored CODE (data adapters), not a dataset — keep it
!toothprint/bench/data/
!toothprint/bench/data/**

# ...and evaluation/fixtures are tiny SYNTHETIC arches for the reproducibility smoke test — keep them
!evaluation/fixtures/
!evaluation/fixtures/**

# generated video intermediates (the final docs/toothprint_showcase.mp4 IS committed)
video/_work/
video/_reel/
video/cli_demo.mp4

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.venv/
venv/

# Env / secrets
.env
*.key
